{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
      "types": ["node"],
        "paths": {
            "@/*": ["./src/*"]
        },
        "strict": true,
        "esModuleInterop": true,
        "lib": [
            "dom",
            "es2018"
        ],
        "jsx": "react-jsx",
      "skipLibCheck": true
    }
}
